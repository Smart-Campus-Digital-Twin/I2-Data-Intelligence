# I2-Data-Intelligence — Environment Configuration
# Smart Campus Analytics Layer Stack
# Copy to .env and configure for your environment

# ============================================================================
# TIMESCALEDB (Main Analytics Database)
# ============================================================================
POSTGRES_DB=campustwin
POSTGRES_USER=ctuser
POSTGRES_PASSWORD=ctpass

# Full connection string for Python services
TIMESCALE_URL=postgresql://ctuser:ctpass@timescaledb:5432/campustwin

# ============================================================================
# REDIS (Cache & Pub/Sub)
# ============================================================================
REDIS_URL=redis://redis:6379

# ============================================================================
# KAFKA & MESSAGE BROKERS
# ============================================================================
KAFKA_BROKERS=kafka:29092
KAFKA_TOPICS_AUTO_CREATE=true

# Schema Registry
SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ============================================================================
# MQTT
# ============================================================================
MQTT_BROKER_HOST=mqtt
MQTT_BROKER_PORT=1883
MQTT_BROKER_USERNAME=
MQTT_BROKER_PASSWORD=

# ============================================================================
# MLFLOW (ML Model Registry & Experiment Tracking)
# ============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT_NAME=smart-campus-twin
MLFLOW_REGISTRY_URI=http://mlflow:5000

# ============================================================================
# INFLUXDB (Time-Series Metrics)
# ============================================================================
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=campus
INFLUXDB_BUCKET=sensor-data
INFLUXDB_TOKEN=your-influxdb-token-here
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpass

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================
# Shared secret for JWT validation (use strong random value in production)
JWT_SECRET=dev-secret-key-change-in-production-min-32-characters-long

# Token expiry (seconds)
JWT_EXPIRY=28800  # 8 hours

# ============================================================================
# SOCKET.IO REAL-TIME RELAY (I2-T6)
# ============================================================================
# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8000

# ============================================================================
# GENERAL
# ============================================================================
NODE_ENV=development
LOG_LEVEL=info
CAMPUS_TIMEZONE=Europe/London
