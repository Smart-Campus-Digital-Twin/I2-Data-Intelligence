# Socket.IO Real-Time Relay Service — Environment Configuration
# Copy this to .env and fill in actual values

# ============================================================================
# KEYCLOAK AUTHENTICATION
# ============================================================================
# Keycloak server URL (e.g., https://keycloak.example.com)
KEYCLOAK_URL=http://keycloak:8080

# Keycloak realm name (e.g., smart-campus)
KEYCLOAK_REALM=smart-campus

# Keycloak client ID for this application (e.g., i2-realtime)
KEYCLOAK_CLIENT_ID=i2-realtime

# ============================================================================
# REDIS
# ============================================================================
# Redis connection URL for Pub/Sub and caching
REDIS_URL=redis://redis:6379

# ============================================================================
# SERVER
# ============================================================================
# Socket.IO server port
PORT=4000

# Allowed CORS origins (comma-separated)
# Default allows frontend on :3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
