{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Member 3 Service",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "uvicorn", "app.main:asgi_app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "Run Tests",
      "type": "shell",
      "command": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
      "args": ["-m", "pytest", "-q"],
      "group": "test",
      "problemMatcher": []
    }
  ]
}
