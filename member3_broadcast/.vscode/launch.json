{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Member 3 Broadcast Service",
      "type": "python",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "app.main:asgi_app",
        "--host",
        "0.0.0.0",
        "--port",
        "8000",
        "--reload"
      ],
      "jinja": true,
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Run Tests",
      "type": "python",
      "request": "launch",
      "module": "pytest",
      "args": ["-q"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
